modules = ["nodejs-20"]

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 21597
externalPort = 3000

[nix]
channel = "stable-25_05"

[workflows]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[deployment]
deploymentTarget = "static"
build = ["pnpm", "--filter", "@workspace/hajj-dashboard", "run", "build"]
publicDir = "artifacts/hajj-dashboard/dist/public"
